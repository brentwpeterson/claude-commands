# Claude Code Template Repository - Exclude sensitive files

# NEVER commit local settings - contains sensitive permissions and paths
settings.local.json

# Exclude project-specific Claude.md files - keep generic template only
Claude.md
CLAUDE.md

# Exclude ALL context files - contain session state and internal workflow details
branch-context/*-context.md
branch-context/archive/
branch-context/archived/
branch-context/later/
branch-context/tomorrow/
!branch-context/feature-example-implementation-context.md
!branch-context/README.md

# CRITICAL: Exclude JSON memory files - may contain sensitive credentials
*.json
!settings.example.json
!settings.no-mcp.json
!package*.json

# Exclude real security scans
security-scans/*.md
!security-scans/README.md

# Exclude real violations
violations/*.md
!violations/README.md

# Exclude inter-Claude communications (internal operational data)
claude-comms/*.md
claude-comms/archive/
!claude-comms/README.md

# Exclude learning logs (internal operational data)
learning/moments/*.md
learning/improvements/
learning/rules-pending/
learning/CLAUDE-LEARNER-PLAN.md
!learning/README.md

# Exclude database/memory files
data/*.sqlite
data/*.sqlite-wal
data/*.sqlite-shm
cb-workspace-memory.json

# Exclude issue logs (internal)
issues/*.md
!issues/README.md

# Exclude archived directories entirely - may contain sensitive historical data
archived-contexts/
archived-commands/

# Local workspace configuration - exclude actual config files but keep templates
local/workspace.env
local/project-overrides.json
local/user-preferences.json
local/*.local.*

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Temporary files
*.tmp
*.temp
*~

